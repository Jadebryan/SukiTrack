# Short-lived access JWT (jsonwebtoken `expiresIn`, e.g. 15m, 1h). Default: 15m
# JWT_ACCESS_EXPIRES_IN=15m
# Refresh token lifetime stored hashed in DB (e.g. 7d, 30d). If unset, falls back to JWT_EXPIRES_IN or 30d.
# JWT_REFRESH_EXPIRES_IN=30d
# Legacy: used only as fallback for refresh TTL when JWT_REFRESH_EXPIRES_IN is unset (not used for access).
# JWT_EXPIRES_IN=90d

# Comma-separated browser origins allowed for CORS (e.g. https://app.example.com,https://admin.example.com).
# Leave empty or use * for permissive CORS (not recommended in production; server logs a warning).
# CORS_ORIGINS=https://your-web-app.example.com

# Password rules (enforced in code): min 8, max 128, at least one letter (A–Z, a–z) and one digit (0–9).
# Mutating actions append rows readable via GET /api/v1/audit-log?limit=50 (same JWT as bootstrap).

# PIN reset email — Gmail (shortcut; kung naka-set, hindi na kailangan ang SMTP_HOST)
# Gumagamit ng smtp.gmail.com:465 + TLS (hindi 587) para maiwasan ang SSL "wrong version number".
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# EMAIL_FROM="Shop Name <shop@gmail.com>"
# Dapat naka-enable ang 2-Step Verification at App Password. Kung iba ang EMAIL_FROM sa GMAIL_USER,
# idagdag ang address sa Gmail → Settings → Accounts → Send mail as.
#
# O generic SMTP (unahin ito kung parehong naka-set ang SMTP_HOST at Gmail vars)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@example.com
# SMTP_PASS=app-password
# SMTP_FROM="SukiTrack <you@example.com>"
#
# O Resend (fallback kung walang SMTP_HOST)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM="SukiTrack <onboarding@resend.dev>"
#
# PIN_RESET_COOLDOWN_MS=60000
# PIN_RESET_PEPPER=optional-extra-secret-for-code-hash

# Rate limits (per IP). Optional overrides — defaults are in server/index.js.
# TRUST_PROXY=1  # set when API sits behind nginx / load balancer (for correct client IP)
# RATE_LIMIT_LOGIN_MAX=30
# RATE_LIMIT_REGISTER_MAX=12
# RATE_LIMIT_FORGOT_PIN_REQUEST_MAX=20
# RATE_LIMIT_FORGOT_PIN_VERIFY_MAX=25
# RATE_LIMIT_CHANGE_PASSWORD_MAX=15
# RATE_LIMIT_REFRESH_MAX=60

# Optional — product sticker images (Cloudinary). If unset, the app saves images on-device only.
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=xxxxxxxxxxxxxxxx
# CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
