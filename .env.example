# Base URL of the Utang API (must match server routes), no trailing slash issues — app trims it.
# Android emulator: http://10.0.2.2:3847/api/v1
# Physical phone: http://YOUR_PC_LAN_IP:3847/api/v1
EXPO_PUBLIC_API_URL=http://192.168.1.100:3847/api/v1

# Optional: encrypt AsyncStorage shop JSON cache at rest (AES-256 key in SecureStore). Set to 1 to enable.
# EXPO_PUBLIC_ENCRYPT_SHOP_CACHE=1
